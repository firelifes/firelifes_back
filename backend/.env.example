# 应用环境：local / sit / prod
NODE_ENV=local

# JWT 密钥
JWT_SECRET=your_jwt_secret_key_change_this

# 数据库配置
DB_HOST=111.230.101.3
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# 腾讯云短信服务配置（可选）
TENCENT_SMS_APP_ID=
TENCENT_SMS_APP_KEY=
TENCENT_SMS_SIGN=
TENCENT_SMS_TEMPLATE=

# Spug 推送 API（用于发送短信验证码）
# 格式：https://push.spug.cc/send/{token}?code={验证码}&targets={手机号}
# 实际调用时 code 和 targets 参数由后端动态拼接
SPUG_PUSH_URL=
